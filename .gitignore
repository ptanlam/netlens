# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# financial data — back up via Export CSV
/data/
# local pulls of the production DB (railway) and their backups — never commit
/production*.db*
/*.db.bak-*

# misc
.DS_Store
*.pem
# ...but public CA intermediates for incomplete upstream TLS chains must ship (lib/tls.ts).
!certs/*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
